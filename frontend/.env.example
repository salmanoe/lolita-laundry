# ── Development without Auth0 ─────────────────────────────────────────────────
# Set VITE_AUTH_MOCK=true to skip Auth0 entirely during local development.
# The backend must be running with SPRING_PROFILES_ACTIVE=dev (the default),
# which permits all requests via DevSecurityConfig.
#
# To use mock mode:
#   echo "VITE_AUTH_MOCK=true" > .env.local   # .env.local is gitignored
#   npm run dev
#
VITE_AUTH_MOCK=false

# ── Auth0 (required when VITE_AUTH_MOCK=false) ────────────────────────────────
# Create a Single Page Application in your Auth0 dashboard.
# Set Allowed Callback URLs:     http://localhost:5173
# Set Allowed Logout URLs:       http://localhost:5173
# Set Allowed Web Origins:       http://localhost:5173
# Create an API in Auth0 with identifier matching VITE_AUTH0_AUDIENCE.

VITE_AUTH0_DOMAIN=dev-orcxwn2q35kltpyb.us.auth0.com
VITE_AUTH0_CLIENT_ID=YOUR_SPA_CLIENT_ID
# Must match the Auth0 API identifier — this makes Auth0 return a JWT (not an opaque token)
VITE_AUTH0_AUDIENCE=YOUR_API_IDENTIFIER

# ── API ───────────────────────────────────────────────────────────────────────
# Leave EMPTY in dev: the Vite proxy (vite.config.ts) forwards /api and /public
# to the backend on :8080. Only set this for builds that talk to a remote backend.
VITE_API_BASE_URL=
